{
  "mcpServers": {
    "github": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "run", "-i", "--rm",
        "-e", "GITHUB_PERSONAL_ACCESS_TOKEN=${GITHUB_TOKEN}",
        "-e", "GITHUB_HOST=https://github.com",
        "ghcr.io/github/github-mcp-server"
      ],
      "env": {}
    }
  }
}
